# ====================================================================
# ENVIRONMENT VARIABLES (KEAMANAN UTAMA)
# ====================================================================
.env
.env.local
.env.production.local
.env.development.local
.env*.local

# ====================================================================
# DEPENDENCIES (JANGAN DI-PUSH, VPS AKAN INSTALL SENDIRI)
# ====================================================================
node_modules/
frontend/node_modules/
backend/vendor/
bin/

# ====================================================================
# BUILD ARTIFACTS & BINARIES
# ====================================================================
# Next.js build
frontend/.next/
frontend/out/
frontend/dist/

# Go/Backend Binaries
backend/server
backend/backend-app
backend/backend-app.exe
backend/main
backend/main.exe
*.exe
*.bin
__debug_bin

# ====================================================================
# UPLOADS & MEDIA (AGAR DATA SISWA DI VPS TIDAK TERTIMPA KOSONG)
# ====================================================================
backend/static/uploads/*
!backend/static/uploads/.gitkeep

# ====================================================================
# LOGS & TEMPORARY FILES
# ====================================================================
*.log
logs/
backend/logs/
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
tmp/
temp/
*.tmp

# ====================================================================
# DATABASE (JANGAN PUSH DATABASE LOKAL KE PRODUKSI)
# ====================================================================
*.db
*.sqlite
*.sqlite3
*.sql
# Jika menggunakan PostgreSQL dump
*.dump

# ====================================================================
# IDE & OS CONFIG
# ====================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ====================================================================
# DOCKER & INFRASTRUCTURE
# ====================================================================
docker-compose.override.yml
